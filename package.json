{
  "name": "nanoshield",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "画面共有中だけ相手の映像に映る機密情報をマスクする Chrome 拡張（自分の画面はそのまま）。",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "wxt prepare && tsc --noEmit && vitest run && wxt build",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "wxt": "^0.20.26"
  }
}
